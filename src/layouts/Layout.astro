---
import "../styles/theme.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import logo from "../assets/noBgColor-logo.svg";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
	pathname?: string;
	alternatePath?: string;
}

const toLocalizedPath = (basePath: string, currentLang: string) =>
	currentLang === "pl"
		? basePath
		: basePath === "/"
			? "/en/"
			: `/en${basePath}`;

const toAlternateLanguagePath = (currentPath: string, currentLang: string) => {
	if (currentLang === "pl") {
		return currentPath === "/" ? "/en/" : `/en${currentPath}`;
	}

	return currentPath === "/en/" ? "/" : currentPath.replace(/^\/en/, "") || "/";
};

const {
	title = "mozgrozmowy.pl",
	description = "Site content coming soon.",
	lang = "pl",
	pathname = "/",
	alternatePath,
} = Astro.props;

const labels =
	lang === "pl"
		? {
				navConversations: "Rozmowy",
				navTopicMap: "Mapa tematow",
				navAbout: "Kontekst",
				homeAriaLabel: "Strona glowna",
				mainNavAriaLabel: "Główna nawigacja",
				switchLabel: "EN",
			}
		: {
				navConversations: "Conversations",
				navTopicMap: "Topic map",
				navAbout: "Context",
				homeAriaLabel: "Home page",
				mainNavAriaLabel: "Main navigation",
				switchLabel: "PL",
			};

const switchHref = alternatePath ?? toAlternateLanguagePath(pathname, lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#ffffff" />
		<meta name="apple-mobile-web-app-title" content="MÓZG" />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner">
				<a
					class="site-brand"
					href={toLocalizedPath("/", lang)}
					aria-label={labels.homeAriaLabel}
				>
					<Image src={logo} alt="Mózg Rozmowy" width={180} loading="eager" />
				</a>

				<nav class="site-nav" aria-label={labels.mainNavAriaLabel}>
					<a
						class:list={{
							active:
								pathname === "/conversations" ||
								pathname.startsWith("/conversations/") ||
								pathname === "/en/conversations" ||
								pathname.startsWith("/en/conversations/"),
						}}
						href={toLocalizedPath("/conversations", lang)}
					>
						{labels.navConversations}
					</a>
					<a
						class:list={{
							active: pathname === "/topic-map" || pathname === "/en/topic-map",
						}}
						href={toLocalizedPath("/topic-map", lang)}
					>
						{labels.navTopicMap}
					</a>
					<a
						class:list={{
							active: pathname === "/about" || pathname === "/en/about",
						}}
						href={toLocalizedPath("/about", lang)}
					>
						{labels.navAbout}
					</a>
				</nav>

				<a
					class="site-lang-switch"
					href={switchHref}
					hreflang={lang === "pl" ? "en" : "pl"}
				>
					{labels.switchLabel}
				</a>
			</div>
		</header>
		<slot />
		<footer class="site-footer">
			Małgorzata Mikołajczyk · Psycholog · analityk zachowania (BCBA)
		</footer>
	</body>
</html>
