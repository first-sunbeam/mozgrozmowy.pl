---
import "../styles/theme.css";
import "../styles/global.css";
import "../styles/dialog-line.css";
import { Image } from "astro:assets";
import logo from "../assets/noBgColor-logo.svg";
import { siteConfig } from "../data/site";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
	pathname?: string;
	alternatePath?: string;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const toLocalizedPath = (basePath: string, currentLang: string) =>
	currentLang === "pl"
		? basePath
		: basePath === "/"
			? "/en/"
			: `/en${basePath}`;

const toAlternateLanguagePath = (currentPath: string, currentLang: string) => {
	if (currentLang === "pl") {
		return currentPath === "/" ? "/en/" : `/en${currentPath}`;
	}

	return currentPath === "/en/" ? "/" : currentPath.replace(/^\/en/, "") || "/";
};

const {
	title = siteConfig.defaultTitle,
	description = siteConfig.defaultDescription,
	lang = "pl",
	pathname = "/",
	alternatePath,
	structuredData,
} = Astro.props;

const labels =
	lang === "pl"
		? {
				navConversations: "Rozmowy",
				navReflections: "Refleksje",
				navTags: "Tagi",
				navTopicMap: "Mapa tematów",
				navAbout: "Kontekst",
				homeAriaLabel: "Strona główna",
				mainNavAriaLabel: "Główna nawigacja",
				switchLabel: "EN",
				menuLabel: "Menu",
				menuOpenLabel: "Otwórz menu",
				menuCloseLabel: "Zamknij menu",
				footerJobTitle: siteConfig.author.jobTitle,
				footerPrivacy: "Polityka prywatności",
			}
		: {
				navConversations: "Conversations",
				navReflections: "Reflections",
				navTags: "Tags",
				navTopicMap: "Topic map",
				navAbout: "Context",
				homeAriaLabel: "Home page",
				mainNavAriaLabel: "Main navigation",
				switchLabel: "PL",
				menuLabel: "Menu",
				menuOpenLabel: "Open menu",
				menuCloseLabel: "Close menu",
				footerJobTitle: "Psychologist · Behavior analyst (BCBA)",
				footerPrivacy: "Privacy policy",
			};

const switchHref = alternatePath ?? toAlternateLanguagePath(pathname, lang);
const canonicalUrl = Astro.site
	? new URL(pathname, Astro.site).href
	: undefined;
const plPath = lang === "pl" ? pathname : switchHref;
const enPath = lang === "en" ? pathname : switchHref;
const plAlternateUrl = Astro.site
	? new URL(plPath, Astro.site).href
	: undefined;
const enAlternateUrl = Astro.site
	? new URL(enPath, Astro.site).href
	: undefined;
const xDefaultUrl = plAlternateUrl;
const ogImageUrl = Astro.site
	? new URL(siteConfig.defaultOgImagePath, Astro.site).href
	: undefined;
const ogLocale = lang === "pl" ? "pl_PL" : "en_US";
const ogAlternateLocale = lang === "pl" ? "en_US" : "pl_PL";
const navItems = [
	{
		label: labels.navConversations,
		href: toLocalizedPath("/conversations", lang),
		active:
			pathname === "/conversations" ||
			pathname.startsWith("/conversations/") ||
			pathname === "/en/conversations" ||
			pathname.startsWith("/en/conversations/"),
	},
	{
		label: labels.navReflections,
		href: toLocalizedPath("/reflections", lang),
		active:
			pathname === "/reflections" ||
			pathname.startsWith("/reflections/") ||
			pathname === "/en/reflections" ||
			pathname.startsWith("/en/reflections/"),
	},
	{
		label: labels.navTags,
		href: toLocalizedPath("/tags", lang),
		active:
			pathname === "/tags" ||
			pathname.startsWith("/tags/") ||
			pathname === "/en/tags" ||
			pathname.startsWith("/en/tags/"),
	},
	{
		label: labels.navTopicMap,
		href: toLocalizedPath("/topic-map", lang),
		active: pathname === "/topic-map" || pathname === "/en/topic-map",
	},
	{
		label: labels.navAbout,
		href: toLocalizedPath("/about", lang),
		active: pathname === "/about" || pathname === "/en/about",
	},
];
const websiteStructuredData = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: siteConfig.siteName,
	url: Astro.site?.href,
	inLanguage: lang,
};
const personStructuredData = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: siteConfig.author.name,
	jobTitle: siteConfig.author.jobTitle,
	url: Astro.site?.href,
};
const structuredDataItems = [
	websiteStructuredData,
	personStructuredData,
	...(structuredData
		? Array.isArray(structuredData)
			? structuredData
			: [structuredData]
		: []),
];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#ffffff" />
		<meta name="apple-mobile-web-app-title" content="MÓZG" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteConfig.siteName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={ogAlternateLocale} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{
			plAlternateUrl && (
				<link rel="alternate" hreflang="pl" href={plAlternateUrl} />
			)
		}
		{
			enAlternateUrl && (
				<link rel="alternate" hreflang="en" href={enAlternateUrl} />
			)
		}
		{
			xDefaultUrl && (
				<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
			)
		}
		{
			structuredDataItems.map((item) => (
				<script
					is:inline
					type="application/ld+json"
					set:html={JSON.stringify(item)}
				/>
			))
		}
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-header__inner" data-header>
				<div class="site-header__top">
					<a class="site-brand" href={toLocalizedPath("/", lang)}>
						<Image src={logo} alt="Mózg Rozmowy" width={180} loading="eager" />
					</a>
					<div>
						<details class="site-nav-details">
							<summary class="site-nav-toggle">
								<span>{labels.menuLabel}</span>
								<span class="site-nav-toggle__icon" aria-hidden="true"></span>
							</summary>
						</details>
						<nav
							id="site-nav-panel"
							class="site-nav"
							aria-label={labels.mainNavAriaLabel}
						>
							{
								navItems.map((item) => (
									<a class:list={{ active: item.active }} href={item.href}>
										{item.label}
									</a>
								))
							}
						</nav>
					</div>
					<div class="site-header__controls">
						<a class="site-lang-switch" href={switchHref}>
							{labels.switchLabel}
						</a>
					</div>
				</div>
			</div>
		</header>
		<slot />
		<footer class="site-footer">
			{siteConfig.author.name} · {labels.footerJobTitle} · <a href={toLocalizedPath("/privacy-policy", lang)}>{labels.footerPrivacy}</a>
		</footer>
	</body>
</html>
