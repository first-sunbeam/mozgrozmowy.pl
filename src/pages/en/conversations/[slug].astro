---
import { render } from "astro:content";
import ConversationArticlePage from "../../../components/pages/ConversationArticlePage.astro";
import { ui } from "../../../i18n/ui";
import {
	getConversationPath,
	getPublishedConversations,
} from "../../../lib/content";

export async function getStaticPaths() {
	const conversations = await getPublishedConversations("en");

	return conversations.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ConversationArticlePage
	entry={entry}
	lang="en"
	pathname={getConversationPath("en", entry.data.slug)}
	kicker={ui.en.article.kicker}
	Content={Content}
/>
