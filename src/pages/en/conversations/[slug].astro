---
import { render } from "astro:content";
import ConversationArticlePage from "../../../components/pages/ConversationArticlePage.astro";
import { ui } from "../../../i18n/ui";
import {
	getConversationPath,
	getConversationStaticPaths,
} from "../../../lib/content";

export async function getStaticPaths() {
	return getConversationStaticPaths("en");
}

const { entry, alternatePath } = Astro.props;
const { Content } = await render(entry);
---

<ConversationArticlePage
	entry={entry}
	lang="en"
	pathname={getConversationPath("en", entry.data.slug)}
	alternatePath={alternatePath}
	kicker={ui.en.article.kicker}
	Content={Content}
/>
