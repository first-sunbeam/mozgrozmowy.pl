---
import TagOverviewPage from "../../components/pages/TagOverviewPage.astro";
import { ui } from "../../i18n/ui";
import { getTagOverviewItems } from "../../lib/content";

const copy = ui.en.tags;
const items = await getTagOverviewItems("en");
---

<TagOverviewPage
	lang="en"
	pathname={copy.pathname}
	alternatePath="/tags"
	title={copy.title}
	description={copy.description}
	kicker={copy.kicker}
	heading={copy.heading}
	intro={copy.intro}
	items={items}
	countSuffix={copy.countSuffix}
/>
