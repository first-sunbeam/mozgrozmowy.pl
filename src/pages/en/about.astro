	intro={copy.intro}
	paragraphs={copy.paragraphs}
	professionalLinkLead={copy.professionalLinkLead}
	professionalLinkLabel={copy.professionalLinkLabel}
	contactLead={copy.contactLead}
	contactLinkLabel={copy.contactLinkLabel}
/>
