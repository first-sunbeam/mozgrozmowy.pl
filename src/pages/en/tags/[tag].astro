---
import ConversationOverviewPage from "../../../components/pages/ConversationOverviewPage.astro";
import { getTagExplanation, getTagExpansion } from "../../../data/tags";
import { ui } from "../../../i18n/ui";
import { getTagStaticPaths } from "../../../lib/content";

export async function getStaticPaths() {
	return getTagStaticPaths("en");
}

const { tag, items, alternatePath } = Astro.props;
const labels = ui.en.tagPage;
const expansion = getTagExpansion("en", tag);
const explanation = getTagExplanation("en", tag);
const displayTag = expansion ? `${tag} (${expansion})` : tag;
const intro = explanation
	? `${labels.introPrefix} “${tag}”. ${explanation}`
	: `${labels.introPrefix} “${tag}”.`;
const description = explanation
	? `${displayTag}. ${items.length} related entries. ${explanation}`
	: `${labels.introPrefix} “${tag}”. ${items.length} related entries.`;
---

<ConversationOverviewPage
	lang="en"
	pathname={`/en/tags/${Astro.params.tag}/`}
	alternatePath={alternatePath}
	title={`${labels.title}: ${displayTag} | mozgrozmowy.pl`}
	description={description}
	kicker={labels.kicker}
	heading={tag}
	intro={intro}
	items={items}
	variant="soft"
/>
