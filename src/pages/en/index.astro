---
import ConversationOverviewPage from "../../components/pages/ConversationOverviewPage.astro";
import { ui } from "../../i18n/ui";
import {
	getPublishedConversations,
	toConversationListItems,
} from "../../lib/content";

const copy = ui.en.home;
const conversations = toConversationListItems(
	(await getPublishedConversations("en")).slice(0, 3),
	"en",
);
---

<ConversationOverviewPage
	lang="en"
	pathname={copy.pathname}
	title={copy.title}
	description={copy.description}
	kicker={copy.kicker}
	heading={copy.heading}
	intro={copy.intro}
	items={conversations}
	variant="soft"
/>
