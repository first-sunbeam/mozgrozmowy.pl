---
import ConversationList from "../../components/ConversationList.astro";
import { conversationsEn } from "../../data/conversations";
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";
---

<Layout
	title="Latest conversations | autyzm.poznan.pl"
	description="Latest conversations from the series."
	lang="en"
	pathname="/en/"
>
	<main class="page-shell">
		<section class="page-intro page-intro--soft">
			<p class="page-kicker">Latest conversations</p>
			<h1>
				Calm, readable conversations about therapy, overload, and systems of
				support.
			</h1>
			<p>
				This homepage shows the latest entries from the series. The structure
				stays simple: clear titles, short descriptions, and space for the
				writing itself.
			</p>
		</section>

		<ConversationList items={conversationsEn.slice(0, 3)} />
	</main>
</Layout>
