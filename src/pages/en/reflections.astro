---
import ConversationOverviewPage from "../../components/pages/ConversationOverviewPage.astro";
import { ui } from "../../i18n/ui";
import {
	getPublishedReflections,
	toReflectionListItems,
} from "../../lib/content";

const copy = ui.en.reflections;
const reflections = toReflectionListItems(await getPublishedReflections("en"), "en");
---

<ConversationOverviewPage
	lang="en"
	pathname={copy.pathname}
	title={copy.title}
	description={copy.description}
	kicker={copy.kicker}
	heading={copy.heading}
	intro={copy.intro}
	items={reflections}
	variant="section"
/>
