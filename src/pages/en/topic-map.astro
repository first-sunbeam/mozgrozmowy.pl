---
import TopicMapPage from "../../components/pages/TopicMapPage.astro";
import { topicMap } from "../../data/topics";
import { ui } from "../../i18n/ui";

const copy = ui.en.topicMap;
---

<TopicMapPage
	lang="en"
	pathname={copy.pathname}
	title={copy.title}
	description={copy.description}
	kicker={copy.kicker}
	heading={copy.heading}
	intro={copy.intro}
	groups={topicMap.en.groups}
	featured={topicMap.en.featured}
	featuredTitle={topicMap.en.featuredTitle}
/>
