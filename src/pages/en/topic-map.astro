---
import TopicMap from "../../components/TopicMap.astro";
import { topicMapEn } from "../../data/conversations";
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";
---

<Layout
	title="Topic map | autyzm.poznan.pl"
	description="Thematic map of the site's content."
	lang="en"
	pathname="/en/topic-map"
>
	<main class="page-shell">
		<section class="page-intro page-intro--alt">
			<p class="page-kicker">Topic map</p>
			<h1>Thematic map of the content</h1>
			<p>
				A grouped view of the ideas running through the site, organized by theme
				instead of chronology.
			</p>
		</section>

		<TopicMap groups={topicMapEn} />
	</main>
</Layout>
