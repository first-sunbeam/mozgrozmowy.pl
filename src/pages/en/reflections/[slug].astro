---
import { render } from "astro:content";
import ConversationArticlePage from "../../../components/pages/ConversationArticlePage.astro";
import { ui } from "../../../i18n/ui";
import { getReflectionPath, getReflectionStaticPaths } from "../../../lib/content";

export async function getStaticPaths() {
	return getReflectionStaticPaths("en");
}

const { entry, alternatePath, previousEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
---

<ConversationArticlePage
	entry={entry}
	lang="en"
	pathname={getReflectionPath("en", entry.data.slug)}
	alternatePath={alternatePath}
	kicker={ui.en.reflectionArticle.kicker}
	previousEntry={previousEntry}
	nextEntry={nextEntry}
	previousLabel={ui.en.article.previousReflectionLabel}
	nextLabel={ui.en.article.nextReflectionLabel}
	Content={Content}
/>
