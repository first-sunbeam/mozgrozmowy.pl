---
import { getCollection } from "astro:content";
import ConversationList from "../../components/ConversationList.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";

const conversations = (await getCollection("conversations", ({ data }) => data.lang === "en" && data.published))
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.map((entry) => ({
		title: entry.data.title,
		description: entry.data.description,
		href: `/en/conversations/${entry.data.slug}`
	}));
---

<Layout
	title="All conversations | mozgrozmowy.pl"
	description="All conversations from the series."
	lang="en"
	pathname="/en/conversations"
>
	<main class="page-shell">
		<section class="page-intro page-intro--section">
			<p class="page-kicker">Conversations</p>
			<h1>All conversations</h1>
			<p>A complete view of the conversation series, kept in one clean list.</p>
		</section>

		<ConversationList items={conversations} />
	</main>
</Layout>
