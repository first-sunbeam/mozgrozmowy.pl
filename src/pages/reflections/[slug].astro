---
import { render } from "astro:content";
import ConversationArticlePage from "../../components/pages/ConversationArticlePage.astro";
import { ui } from "../../i18n/ui";
import { getReflectionPath, getReflectionStaticPaths } from "../../lib/content";

export async function getStaticPaths() {
	return getReflectionStaticPaths("pl");
}

const { entry, alternatePath, previousEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
---

<ConversationArticlePage
	entry={entry}
	lang="pl"
	pathname={getReflectionPath("pl", entry.data.slug)}
	alternatePath={alternatePath}
	kicker={ui.pl.reflectionArticle.kicker}
	previousEntry={previousEntry}
	nextEntry={nextEntry}
	previousLabel={ui.pl.article.previousReflectionLabel}
	nextLabel={ui.pl.article.nextReflectionLabel}
	Content={Content}
/>
