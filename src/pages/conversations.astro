---
import { getCollection } from "astro:content";
import ConversationList from "../components/ConversationList.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/content-pages.css";

const conversations = (await getCollection("conversations", ({ data }) => data.lang === "pl" && data.published))
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
	.map((entry) => ({
		title: entry.data.title,
		description: entry.data.description,
		href: `/conversations/${entry.data.slug}`
	}));
---

<Layout
	title="Wszystkie rozmowy | mozgrozmowy.pl"
	description="Wszystkie rozmowy z serii."
	lang="pl"
	pathname="/conversations"
>
	<main class="page-shell">
		<section class="page-intro page-intro--section">
			<p class="page-kicker">Rozmowy</p>
			<h1>Wszystkie rozmowy</h1>
			<p>Pełny widok serii rozmów zebrany w jednej, czytelnej liście.</p>
		</section>

		<ConversationList items={conversations} />
	</main>
</Layout>
