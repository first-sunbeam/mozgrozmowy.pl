---
import TopicMapComponent from "../components/TopicMap.astro";
import { topicMap } from "../data/topics";
import Layout from "../layouts/Layout.astro";
import "../styles/content-pages.css";
---

<Layout
	title="Mapa tematów | mozgrozmowy.pl"
	description="Tematyczna mapa treści na stronie."
	lang="pl"
	pathname="/topic-map"
>
	<main class="page-shell">
		<section class="page-intro page-intro--alt">
			<p class="page-kicker">Mapa tematów</p>
			<h1>Tematyczna mapa treści</h1>
			<p>
				Pogrupowany widok wątków obecnych na stronie, uporządkowany według tematów,
				a nie chronologii.
			</p>
		</section>

		<TopicMapComponent groups={topicMap.pl} />
	</main>
</Layout>
