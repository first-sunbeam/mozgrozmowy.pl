	lang="pl"
	pathname={copy.pathname}
	title={copy.title}
	description={copy.description}
	kicker={copy.kicker}
	heading={copy.heading}
	intro={copy.intro}
	paragraphs={copy.paragraphs}
	contactLead={copy.contactLead}
	contactLinkLabel={copy.contactLinkLabel}
/>
