---
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";
import { getTagPath } from "../../data/tags";
import { siteConfig } from "../../data/site";
import { ui } from "../../i18n/ui";
import type { Lang } from "../../i18n/ui";
import type { ArticleEntry, ArticleNavItem } from "../../lib/content";

interface Props {
	entry: ArticleEntry;
	lang: Lang;
	pathname: string;
	alternatePath?: string;
	kicker: string;
	previousEntry?: ArticleNavItem;
	nextEntry?: ArticleNavItem;
	previousLabel?: string;
	nextLabel?: string;
	Content: any;
}

const {
	entry,
	lang,
	pathname,
	alternatePath,
	kicker,
	previousEntry,
	nextEntry,
	previousLabel,
	nextLabel,
	Content,
} = Astro.props;

const articleUrl = Astro.site ? new URL(pathname, Astro.site).href : undefined;
const publisherLogoUrl = Astro.site
	? new URL(siteConfig.defaultOgImagePath, Astro.site).href
	: undefined;
const labels = ui[lang].article;
const dateLocale = lang === "pl" ? "pl-PL" : "en-US";
const formatDate = (date: Date) =>
	new Intl.DateTimeFormat(dateLocale, {
		year: "numeric",
		month: "long",
		day: "numeric",
	}).format(date);
const publishedDate = formatDate(entry.data.publishedAt);
const updatedDate = entry.data.updatedAt ? formatDate(entry.data.updatedAt) : undefined;

const articleStructuredData = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description: entry.data.description,
	url: articleUrl,
	mainEntityOfPage: articleUrl,
	datePublished: entry.data.publishedAt.toISOString(),
	dateModified: entry.data.updatedAt?.toISOString(),
	inLanguage: lang,
	author: {
		"@type": "Person",
		name: siteConfig.author.name,
	},
	publisher: {
		"@type": "Organization",
		name: siteConfig.siteName,
		url: Astro.site?.href,
		logo: publisherLogoUrl
			? {
					"@type": "ImageObject",
					url: publisherLogoUrl,
				}
			: undefined,
	},
};
---

<Layout
	title={`${entry.data.title} | mozgrozmowy.pl`}
	description={entry.data.description}
	lang={lang}
	pathname={pathname}
	alternatePath={alternatePath}
	structuredData={articleStructuredData}
>
	<main class="page-shell">
		<article class="article-shell surface-card">
			<p class="page-kicker">{kicker}</p>
			<h1>{entry.data.title}</h1>
			<p class="article-meta">
				{labels.publishedLabel}: <time datetime={entry.data.publishedAt.toISOString()}>{publishedDate}</time>
				{updatedDate && (
					<>
						<span aria-hidden="true"> · </span>
						{labels.updatedLabel}: <time datetime={entry.data.updatedAt?.toISOString()}>{updatedDate}</time>
					</>
				)}
			</p>
			<p class="article-description">{entry.data.description}</p>
			{entry.data.topics.length > 0 && (
				<div class="article-tags">
					<span class="article-tags__label">{labels.tagsLabel}:</span>
					<ul class="article-tags__list">
						{entry.data.topics.map((tag) => (
							<li>
								<a href={getTagPath(lang, tag)}>{tag}</a>
							</li>
						))}
					</ul>
				</div>
			)}
			<div class="article-content">
				<Content />
			</div>
			{(previousEntry || nextEntry) && (
				<nav class="article-pagination" aria-label="Article pagination">
					{previousEntry ? (
						<a class="article-pagination__link surface-card" href={previousEntry.href}>
							<span class="article-pagination__label">{previousLabel}</span>
							<span class="article-pagination__title">{previousEntry.title}</span>
						</a>
					) : (
						<span></span>
					)}
					{nextEntry ? (
						<a class="article-pagination__link article-pagination__link--next surface-card" href={nextEntry.href}>
							<span class="article-pagination__label">{nextLabel}</span>
							<span class="article-pagination__title">{nextEntry.title}</span>
						</a>
					) : (
						<span></span>
					)}
				</nav>
			)}
		</article>
	</main>
</Layout>

<style>
	.article-shell {
		padding: 1.75rem;
		border-radius: 24px;
		max-width: 70ch;
		margin-left: auto;
		margin-right: auto;
	}

	.article-shell h1 {
		margin: 0 0 1rem;
		font-size: clamp(1.55rem, 3.4vw, 2rem);
		line-height: 1.12;
	}

	.article-meta {
		margin: 0 0 0.9rem;
		color: var(--color-text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.article-description {
		margin: 0 0 1.5rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.article-tags {
		margin: 0 0 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
	}

	.article-tags__label {
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--color-text-secondary);
	}

	.article-tags__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.article-tags__list a {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.7rem;
		border: 1px solid var(--border-light);
		border-radius: 999px;
		background: color-mix(in srgb, var(--bg-main) 82%, var(--color-bg-light) 18%);
		color: var(--color-text-secondary);
		text-decoration: none;
		font-size: 0.92rem;
		line-height: 1.2;
	}

	.article-tags__list a:hover {
		color: var(--color-primary-hover);
		border-color: color-mix(in srgb, var(--border-light) 60%, var(--color-primary) 40%);
	}

	.article-content :global(h2) {
		font-size: clamp(1.18rem, 2.2vw, 1.42rem);
		line-height: 1.2;
	}

	.article-content :global(h3) {
		font-size: clamp(1rem, 1.7vw, 1.16rem);
		line-height: 1.25;
	}

	.article-pagination {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border-light);
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.article-pagination__link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem;
		border-radius: 18px;
		background: color-mix(in srgb, var(--bg-main) 84%, var(--color-bg-light) 16%);
		text-decoration: none;
		color: var(--color-text-primary);
		min-height: 100%;
	}

	.article-pagination__link--next {
		text-align: right;
	}

	.article-pagination__label {
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-primary);
		font-weight: 700;
	}

	.article-pagination__title {
		font-weight: 600;
		line-height: 1.45;
	}

	.article-pagination__link:hover .article-pagination__title {
		color: var(--color-primary-hover);
	}

	@media (max-width: 720px) {
		.article-pagination {
			grid-template-columns: 1fr;
		}

		.article-pagination__link--next {
			text-align: left;
		}
	}
</style>
