---
import TopicMapComponent from "../TopicMap.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";
import type { Lang } from "../../i18n/ui";

interface TopicItem {
	title: string;
	href: string;
	kind?: string;
	description?: string;
}

interface TopicGroup {
	title: string;
	items: TopicItem[];
}

interface Props {
	lang: Lang;
	pathname: string;
	title: string;
	description: string;
	kicker: string;
	heading: string;
	intro: string;
	groups: TopicGroup[];
	featured?: TopicItem[];
	featuredTitle?: string;
}

const {
	lang,
	pathname,
	title,
	description,
	kicker,
	heading,
	intro,
	groups,
	featured,
	featuredTitle,
} = Astro.props;
---

<Layout title={title} description={description} lang={lang} pathname={pathname}>
	<main class="page-shell">
		<section class="page-intro page-intro--alt">
			<p class="page-kicker">{kicker}</p>
			<h1>{heading}</h1>
			<p>{intro}</p>
		</section>

		<TopicMapComponent groups={groups} featured={featured} featuredTitle={featuredTitle} />
	</main>
</Layout>
