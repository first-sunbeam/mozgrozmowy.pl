---
import Layout from "../../layouts/Layout.astro";
import "../../styles/content-pages.css";
import { contactEmail } from "../../data/site";
import type { Lang } from "../../i18n/ui";

interface Props {
	lang: Lang;
	pathname: string;
	title: string;
	description: string;
	kicker: string;
	heading: string;
	intro: string;
	paragraphs: readonly string[];
	contactLead: string;
	contactLinkLabel: string;
}

const {
	lang,
	pathname,
	title,
	description,
	kicker,
	heading,
	intro,
	paragraphs,
	contactLead,
	contactLinkLabel,
} = Astro.props;

const contactHref = `mailto:${contactEmail}`;
---

<Layout title={title} description={description} lang={lang} pathname={pathname}>
	<main class="page-shell">
		<section class="page-intro page-intro--alt">
			<p class="page-kicker">{kicker}</p>
			<h1>{heading}</h1>
			<p>{intro}</p>
		</section>

		<section class="about-card surface-card">
			{paragraphs.map((paragraph) => <p>{paragraph}</p>)}
			<p>
				{contactLead}
				<a href={contactHref}>{contactLinkLabel}</a>.
			</p>
		</section>
	</main>
</Layout>
