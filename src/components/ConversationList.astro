---
interface ConversationListItem {
	title: string;
	description: string;
	href: string;
}

interface Props {
	items: ConversationListItem[];
}

const { items } = Astro.props;
---

<div class="conversation-list">
	{items.map((item) => (
		<article class="conversation-card surface-card">
			<h2>
				<a href={item.href}>{item.title}</a>
			</h2>
			<p>{item.description}</p>
		</article>
	))}
</div>

<style>
	.conversation-list {
		display: grid;
		gap: 1rem;
	}

	.conversation-card {
		padding: 1.5rem;
		border-radius: 20px;
	}

	.conversation-card h2 {
		margin: 0 0 0.75rem;
		font-size: 1.1rem;
		line-height: 1.35;
		color: var(--color-text-primary);
	}

	.conversation-card h2 a {
		color: inherit;
		text-decoration: none;
	}

	.conversation-card h2 a:hover {
		color: var(--color-primary-hover);
	}

	.conversation-card p {
		margin: 0;
		max-width: 62ch;
		color: var(--color-text-secondary);
		font-size: 1rem;
		line-height: 1.65;
	}
</style>
