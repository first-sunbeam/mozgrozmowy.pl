---
interface TopicItem {
	title: string;
	href: string;
	kind?: string;
	description?: string;
}

interface TopicGroup {
	title: string;
	items: TopicItem[];
}

interface Props {
	groups: TopicGroup[];
	featured?: TopicItem[];
	featuredTitle?: string;
}

const { groups, featured = [], featuredTitle } = Astro.props;
---

<div class="topic-map-layout">
	{featured.length > 0 && (
		<section class="topic-featured surface-card">
			<h2>{featuredTitle}</h2>
			<div class="topic-featured__grid">
				{featured.map((item) => (
					<article class="topic-featured__card surface-card">
						<p class="topic-featured__meta">{item.kind}</p>
						<h3><a href={item.href}>{item.title}</a></h3>
						{item.description && <p>{item.description}</p>}
					</article>
				))}
			</div>
		</section>
	)}

	<div class="topic-map">
		{groups.map((group) => (
			<section class="topic-group surface-card">
				<h2>{group.title}</h2>
				<ul>
					{group.items.map((item) => (
						<li>
							<div class="topic-item__row">
								<a href={item.href}>{item.title}</a>
								{item.kind && <span class="topic-kind">{item.kind}</span>}
							</div>
							{item.description && <p class="topic-item__description">{item.description}</p>}
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</div>

<style>
	.topic-map-layout {
		display: grid;
		gap: 1rem;
	}

	.topic-featured,
	.topic-group {
		padding: 1.5rem;
		border-radius: 20px;
		margin-bottom: 1rem;
	}

	.topic-featured {
		background: var(--color-white);
	}

	.topic-group {
		background: color-mix(in srgb, var(--bg-main) 82%, var(--color-bg-light) 18%);
	}

	.topic-featured h2,
	.topic-group h2 {
		margin: 0 0 0.9rem;
		font-size: 1.02rem;
		color: var(--color-text-primary);
	}

	.topic-featured__grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.topic-featured__card {
		padding: 1rem;
		border-radius: 16px;
		background: color-mix(in srgb, var(--bg-main) 84%, var(--color-bg-light) 16%);
	}

	.topic-featured__meta {
		margin: 0 0 0.4rem;
		font-size: 0.76rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-primary);
		font-weight: 700;
	}

	.topic-featured__card h3 {
		margin: 0 0 0.45rem;
		font-size: 0.96rem;
		line-height: 1.35;
	}

	.topic-featured__card h3 a,
	.topic-group a {
		color: var(--color-text-primary);
		text-decoration: none;
		font-weight: 600;
	}

	.topic-featured__card h3 a:hover,
	.topic-group a:hover {
		color: var(--color-primary-hover);
	}

	.topic-featured__card p:last-child,
	.topic-item__description {
		margin: 0.35rem 0 0;
		color: var(--color-text-secondary);
		line-height: 1.55;
		font-size: 0.95rem;
	}

	.topic-group ul {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--color-text-secondary);
	}

	.topic-group li + li {
		margin-top: 0.85rem;
	}

	.topic-item__row {
		display: flex;
		gap: 0.6rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.topic-kind {
		padding: 0.14rem 0.5rem;
		border-radius: 999px;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-primary);
		background: color-mix(in srgb, var(--color-primary) 10%, white 90%);
		border: 1px solid color-mix(in srgb, var(--color-primary) 18%, white 82%);
	}
</style>
